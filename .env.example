# NexusAgent Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── LLM Providers (at least one required) ─────────────────────────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Search (optional, enables web search) ──────────────────────────────
EXA_API_KEY=
TAVILY_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────
NEXUS_PORT=8000
